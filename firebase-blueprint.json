{
  "entities": {
    "QuoteRequest": {
      "title": "Quote Request",
      "description": "A request for a quote from a potential customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "message": { "type": "string", "description": "Details of the project or products needed" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed", "ordered", "revision_requested"], "description": "Status of the request" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "UID of the user who submitted (if logged in)" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A sanitaryware or fitting product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "category", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "return_requested", "refunded", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "quoteId": { "type": "string" },
        "items": { "type": "array", "description": "List of items in the order" },
        "total": { "type": "number" },
        "internalNotes": { "type": "array", "description": "Internal notes for the order" },
        "timeline": { "type": "array", "description": "Timeline of order events" }
      },
      "required": ["customerName", "email", "status", "createdAt", "items", "total"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A customer invoice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "partial"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date" },
        "items": { "type": "array" },
        "paidAmount": { "type": "number" },
        "payments": { "type": "array" },
        "isRecurring": { "type": "boolean" },
        "frequency": { "type": "string", "enum": ["monthly", "quarterly", "yearly"] }
      },
      "required": ["customerName", "email", "total", "status", "createdAt"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "An item in the stock/inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["in-stock", "low-stock", "out-of-stock"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "stock", "minStock", "category", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A product supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "website": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "status"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "A live visitor on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "city": { "type": "string" },
        "page": { "type": "string" },
        "device": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "action": { "type": "string" },
        "duration": { "type": "number" }
      },
      "required": ["id", "lastActive"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "A record of an action taken within the admin panel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the user who took the action" },
        "userEmail": { "type": "string", "description": "Email of the user who took the action" },
        "action": { "type": "string", "description": "The action taken (e.g., 'create_product', 'delete_quote')" },
        "details": { "type": "string", "description": "Additional details about the action" },
        "ip": { "type": "string", "description": "IP address of the user" },
        "device": { "type": "string", "description": "Device/Browser info" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "createdAt"]
    },
    "Page": {
      "title": "Page",
      "description": "A website page created via the Page Builder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "status", "createdAt"]
    }
  },
  "firestore": {
    "quotes": {
      "schema": "QuoteRequest",
      "description": "Collection of quote requests"
    },
    "products": {
      "schema": "Product",
      "description": "Collection of products available for sale"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "inventory": {
      "schema": "InventoryItem",
      "description": "Collection of inventory items"
    },
    "suppliers": {
      "schema": "Supplier",
      "description": "Collection of product suppliers"
    },
    "visitors": {
      "schema": "Visitor",
      "description": "Collection of live visitors"
    },
    "audit_logs": {
      "schema": "AuditLog",
      "description": "Collection of audit logs for admin actions"
    },
    "pages": {
      "schema": "Page",
      "description": "Collection of website pages"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Collection of customer invoices"
    }
  }
}
